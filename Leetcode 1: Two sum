class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap<Integer,Integer> map= new HashMap<>();
        int arr[]= new int[2];
        for(int i=0;i<nums.length;i++)
        {
            
           int first=nums[i];
            if(map.containsKey(target-first))
            {
                arr[0]=map.get(target-first);
                arr[1]=i;
            }
            map.put(nums[i],i);
        }
        return arr;

        
    }
}
